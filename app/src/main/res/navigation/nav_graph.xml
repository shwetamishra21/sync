<?xml version="1.0" encoding="utf-8"?>

<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash -->

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.jsac.sync.presentation.splash.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"/>

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <!-- Login -->

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.jsac.sync.presentation.auth.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"/>
    </fragment>

    <!-- Register -->

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.jsac.sync.presentation.auth.RegisterFragment"
        android:label="Register">

        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"/>
    </fragment>

    <!-- Home -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.jsac.sync.presentation.home.HomeFragment"
        android:label="Home">

        <!-- NEW ACTION: Navigate from Home back to Login on logout -->
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
    </fragment>
    <!-- Add these actions to loginFragment -->
    <action
        android:id="@+id/action_login_to_forgot_password"
        app:destination="@id/forgotPasswordFragment"/>

    <!-- Add these fragments -->
    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.jsac.sync.presentation.auth.ForgotPasswordFragment"
        android:label="Forgot Password">

        <action
            android:id="@+id/action_forgot_password_to_reset_password"
            app:destination="@id/resetPasswordFragment"/>
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.jsac.sync.presentation.auth.ResetPasswordFragment"
        android:label="Reset Password">

        <action
            android:id="@+id/action_reset_password_to_login"
            app:destination="@id/loginFragment"/>
    </fragment>
</navigation>