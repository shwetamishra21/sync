<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginTop="@dimen/space_sm">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_md">

        <!-- Form name -->
        <TextView
            android:id="@+id/tvFormName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/SectionTitle"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chipStatus"
            tools:text="Contact Form" />

        <!-- Status chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:textColor="@color/white"
            app:chipBackgroundColor="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Pending" />

        <!-- Date row -->
        <ImageView
            android:id="@+id/ivDate"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="@dimen/space_sm"
            android:src="@drawable/ic_calendar"
            android:importantForAccessibility="no"
            app:layout_constraintTop_toBottomOf="@id/tvFormName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tvDate" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_xs"
            android:layout_marginTop="@dimen/space_sm"
            style="@style/SubtitleText"
            app:layout_constraintTop_toBottomOf="@id/tvFormName"
            app:layout_constraintStart_toEndOf="@id/ivDate"
            app:layout_constraintEnd_toStartOf="@id/tvRetryCount"
            tools:text="Jun 10, 2026 · 14:30" />

        <!-- Retry badge (only visible when retry_count > 0) -->
        <TextView
            android:id="@+id/tvRetryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_repeat"
            android:drawablePadding="@dimen/space_xs"
            android:gravity="center_vertical"
            style="@style/SubtitleText"
            app:layout_constraintTop_toTopOf="@id/tvDate"
            app:layout_constraintBottom_toBottomOf="@id/tvDate"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="↻ 2" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/space_md"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/tvDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Action row -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSync"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/btn_sync"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_sync"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/space_xs"
            app:cornerRadius="4dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/space_sm"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:contentDescription="@string/btn_delete"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/space_xs"
            android:src="@drawable/ic_chevron_right"
            android:importantForAccessibility="no"
            app:layout_constraintTop_toTopOf="@id/btnDelete"
            app:layout_constraintBottom_toBottomOf="@id/btnDelete"
            app:layout_constraintEnd_toStartOf="@id/btnDelete" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>