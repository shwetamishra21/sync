<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginTop="@dimen/space_sm"
    android:layout_marginBottom="@dimen/space_sm"
    app:cardCornerRadius="@dimen/corner_large"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_lg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFormName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/SectionTitle"/>

            <TextView
                android:id="@+id/tvFormDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:maxLines="2"
                android:ellipsize="end"
                style="@style/SubtitleText"/>

            <TextView
                android:id="@+id/tvFieldCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                style="@style/BodyText"
                android:textColor="@color/primary"/>

        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/text_secondary"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>