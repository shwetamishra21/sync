<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JSAC"
            android:textStyle="bold"
            android:textSize="30sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Workflow Management"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>

        <!-- Sync Card -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync Status"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Everything synced"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvPendingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0 Pending"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/progressBarSync"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Quick Actions -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnViewForms"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Forms"
                android:textAllCaps="false"
                android:background="@drawable/bg_primary_button"/>

            <Space
                android:layout_width="16dp"
                android:layout_height="1dp"/>

            <Button
                android:id="@+id/btnViewSubmissions"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Submissions"
                android:textAllCaps="false"
                android:background="@drawable/bg_secondary_button"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnManualSync"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="@string/btn_sync_now"
            android:textAllCaps="false"
            android:background="@drawable/bg_primary_button"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/logout"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_danger"/>

    </LinearLayout>

</ScrollView>