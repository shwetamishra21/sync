<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="@dimen/space_sm">

    <TextView
        android:id="@+id/tvFieldLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Sync.Label"
        tools:text="EMAIL ADDRESS" />

    <TextView
        android:id="@+id/tvFieldValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xxs"
        android:textAppearance="@style/TextAppearance.Sync.Body"
        tools:text="citizen@example.gov.in" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_thickness"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@color/divider" />

</LinearLayout>