<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- ============================================ -->
    <!-- SPLASH FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.jsac.sync.presentation.splash.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"/>

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <!-- ============================================ -->
    <!-- LOGIN FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.jsac.sync.presentation.auth.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"/>

        <action
            android:id="@+id/action_login_to_forgot_password"
            app:destination="@id/forgotPasswordFragment"/>
    </fragment>

    <!-- ============================================ -->
    <!-- REGISTER FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.jsac.sync.presentation.auth.RegisterFragment"
        android:label="Register">

        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"/>
    </fragment>

    <!-- ============================================ -->
    <!-- FORGOT PASSWORD FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.jsac.sync.presentation.auth.ForgotPasswordFragment"
        android:label="Forgot Password">

        <action
            android:id="@+id/action_forgot_password_to_reset_password"
            app:destination="@id/resetPasswordFragment"/>

        <action
            android:id="@+id/action_forgot_password_to_login"
            app:destination="@id/loginFragment"/>
    </fragment>

    <!-- ============================================ -->
    <!-- RESET PASSWORD FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.jsac.sync.presentation.auth.ResetPasswordFragment"
        android:label="Reset Password">

        <action
            android:id="@+id/action_reset_password_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ============================================ -->
    <!-- HOME FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.jsac.sync.presentation.home.HomeFragment"
        android:label="Home">

        <!-- Navigation to Dashboard -->
        <action
            android:id="@+id/action_home_to_dashboard"
            app:destination="@id/dashboardFragment"/>

        <!-- Navigation to Submissions List (NEW) -->
        <action
            android:id="@+id/action_home_to_submissions"
            app:destination="@id/submissionsListFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right"/>

        <!-- Logout back to Login -->
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- ============================================ -->
    <!-- DASHBOARD FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.jsac.sync.presentation.dashboard.DashboardFragment"
        android:label="Dashboard">

        <!-- Navigation to Form Detail -->
        <action
            android:id="@+id/action_dashboard_to_form_detail"
            app:destination="@id/formDetailFragment"/>

        <!-- Navigation back to Home -->
        <action
            android:id="@+id/action_dashboard_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <!-- ============================================ -->
    <!-- FORM DETAIL FRAGMENT -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/formDetailFragment"
        android:name="com.jsac.sync.presentation.dashboard.FormDetailFragment"
        android:label="Form Detail">

        <!-- Add arguments if needed -->
        <argument
            android:name="formId"
            app:argType="string"
            android:defaultValue=""/>
    </fragment>

    <!-- ============================================ -->
    <!-- SUBMISSIONS LIST FRAGMENT (NEW) -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/submissionsListFragment"
        android:name="com.jsac.sync.presentation.submissions.SubmissionsListFragment"
        android:label="📋 Saved Submissions">

        <!-- Navigation to Submission Detail -->
        <action
            android:id="@+id/action_submissions_to_detail"
            app:destination="@id/submissionDetailFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right"/>

        <!-- Back to Home -->
        <action
            android:id="@+id/action_submissions_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <!-- ============================================ -->
    <!-- SUBMISSION DETAIL FRAGMENT (NEW) -->
    <!-- ============================================ -->

    <fragment
        android:id="@+id/submissionDetailFragment"
        android:name="com.jsac.sync.presentation.submissions.SubmissionDetailFragment"
        android:label="📋 Submission Details">

        <!-- Arguments -->
        <argument
            android:name="submissionId"
            app:argType="integer"
            android:defaultValue="0"/>

        <!-- Back to Submissions List -->
        <action
            android:id="@+id/action_detail_to_submissions"
            app:destination="@id/submissionsListFragment"
            app:popUpTo="@id/submissionsListFragment"
            app:popUpToInclusive="false"/>
    </fragment>

</navigation>