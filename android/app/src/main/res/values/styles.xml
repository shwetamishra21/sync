<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ====================================================== -->
    <!-- Legacy Styles -->
    <!-- ====================================================== -->

    <style name="TitleText">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="SubtitleText">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ====================================================== -->
    <!-- Base Typography -->
    <!-- ====================================================== -->

    <style
        name="TextAppearance.Sync"
        parent="TextAppearance.MaterialComponents.Body1">

        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>

    </style>

    <style
        name="TextAppearance.Sync.Headline"
        parent="TextAppearance.Sync">

        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <style
        name="TextAppearance.Sync.Title"
        parent="TextAppearance.Sync">

        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <style
        name="TextAppearance.Sync.Label"
        parent="TextAppearance.Sync">

        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>

    </style>

    <style
        name="TextAppearance.Sync.Body"
        parent="TextAppearance.Sync">

        <item name="android:textSize">16sp</item>

    </style>

    <style
        name="TextAppearance.Sync.BodySmall"
        parent="TextAppearance.Sync">

        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>

    </style>

    <!-- ====================================================== -->
    <!-- Toolbar -->
    <!-- ====================================================== -->

    <style
        name="Widget.Sync.Toolbar"
        parent="Widget.MaterialComponents.Toolbar">

        <item name="backgroundTint">@color/primary</item>
        <item name="titleTextColor">@android:color/white</item>
        <item name="navigationIconTint">@android:color/white</item>

    </style>

    <!-- ====================================================== -->
    <!-- Buttons -->
    <!-- ====================================================== -->

    <style
        name="Widget.Sync.Button.Filled"
        parent="Widget.Material3.Button">

        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@android:color/white</item>

    </style>

    <style
        name="Widget.Sync.Button.Outlined"
        parent="Widget.Material3.Button.OutlinedButton">

        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>

    </style>

    <!-- ====================================================== -->
    <!-- Chips -->
    <!-- ====================================================== -->

    <style
        name="Widget.Sync.Chip.Pending"
        parent="Widget.Material3.Chip.Assist">

        <item name="chipBackgroundColor">@color/status_pending_bg</item>
        <item name="android:textColor">@color/status_pending_fg</item>

    </style>

</resources>