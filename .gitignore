# Clean up .gitignore
cat > .gitignore << 'EOF'
# Android
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# Python & Backend
__pycache__/
*.pyc
.env
.ipynb_checkpoints/
*.bin
*.safetensors

# System
OneDrive/
notebooks/
Downloads/
Videos/
EOF

# Stage and commit
git add .gitignore
git commit -m "fix: resolve .gitignore merge conflicts"